{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/ar/api/(.*)", "destination": "/api/$1" },
    { "source": "/team/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/card/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/services/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ai-workforce/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/integrations/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/work/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/contact/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/admin/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/team/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/card/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/services/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/ai-workforce/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/integrations/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/work/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/ar/contact/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/services/ai-agents", "destination": "/index.html" },
    { "source": "/services/automations", "destination": "/index.html" },
    { "source": "/services/ai-deployment", "destination": "/index.html" },
    { "source": "/services/websites", "destination": "/index.html" },
    { "source": "/services/growth", "destination": "/index.html" },
    { "source": "/services/voice-ai", "destination": "/index.html" },
    { "source": "/ar/services/ai-agents", "destination": "/index.html" },
    { "source": "/ar/services/automations", "destination": "/index.html" },
    { "source": "/ar/services/ai-deployment", "destination": "/index.html" },
    { "source": "/ar/services/websites", "destination": "/index.html" },
    { "source": "/ar/services/growth", "destination": "/index.html" },
    { "source": "/ar/services/voice-ai", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/ai-workforce", "destination": "/index.html" },
    { "source": "/integrations", "destination": "/index.html" },
    { "source": "/work", "destination": "/index.html" },
    { "source": "/team", "destination": "/index.html" },
    { "source": "/team/:slug", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/card/:slug", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/ar", "destination": "/index.html" },
    { "source": "/ar/services", "destination": "/index.html" },
    { "source": "/ar/ai-workforce", "destination": "/index.html" },
    { "source": "/ar/integrations", "destination": "/index.html" },
    { "source": "/ar/work", "destination": "/index.html" },
    { "source": "/ar/team", "destination": "/index.html" },
    { "source": "/ar/team/:slug", "destination": "/index.html" },
    { "source": "/ar/contact", "destination": "/index.html" },
    { "source": "/ar/card/:slug", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/videos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
