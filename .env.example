# AI Handle — Environment Variables
# Copy this file to .env.local and fill in values.
# Variables prefixed with VITE_ are exposed to the browser.
# All other secrets must remain server-side only.

# ─── Supabase ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Mistral AI (server-side only) ───
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ─── Telegram Bot (server-side only) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─── Jarvis Command Center (server-side only) ───
JARVIS_COMMAND_CENTER_URL=
JARVIS_API_TOKEN=

# ─── Site ───
SITE_PUBLIC_URL=https://aihandle.cloud
